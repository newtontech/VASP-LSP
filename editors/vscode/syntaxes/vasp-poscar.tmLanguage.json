{
  "name": "poscar",
  "scopeName": "source.vasp.poscar",
  "patterns": [
    {
      "include": "#comment"
    },
    {
      "include": "#number"
    },
    {
      "include": "#element"
    }
  ],
  "repository": {
    "comment": {
      "match": "[#].*$",
      "name": "comment.line.number-sign.vasp"
    },
    "number": {
      "match": "[-+]?[0-9]*\\.?[0-9]+([eE][-+]?[0-9]+)?",
      "name": "constant.numeric.vasp"
    },
    "element": {
      "match": "\\b(H|He|Li|Be|B|C|N|O|F|Ne|Na|Mg|Al|Si|P|S|Cl|Ar|K|Ca|Sc|Ti|V|Cr|Mn|Fe|Co|Ni|Cu|Zn|Ga|Ge|As|Se|Br|Kr|Rb|Sr|Y|Zr|Nb|Mo|Tc|Ru|Rh|Pd|Ag|Cd|In|Sn|Sb|Te|I|Xe|Cs|Ba|La|Ce|Pr|Nd|Pm|Sm|Eu|Gd|Tb|Dy|Ho|Er|Tm|Yb|Lu|Hf|Ta|W|Re|Os|Ir|Pt|Au|Hg|Tl|Pb|Bi|Po|At|Rn|Fr|Ra|Ac|Th|Pa|U|Np|Pu|Am|Cm|Bk|Cf|Es|Fm|Md|No|Lr)\\b",
      "name": "entity.name.element.vasp"
    }
  }
}
